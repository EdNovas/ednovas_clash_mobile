name: ednovas_clash_mobile
description: A new Flutter project for EdNovas Clash.
publish_to: 'none'
version: 1.0.0+1

environment:
  sdk: '>=3.1.0 <4.0.0'

dependencies:
  flutter:
    sdk: flutter
  
  # State Management
  provider: ^6.1.1
  
  # Networking
  dio: ^5.4.0
  
  # UI & Animations
  flutter_animate: ^4.5.0
  google_fonts: ^6.1.0
  gap: ^3.0.0
  modal_bottom_sheet: ^3.0.0-pre
  fl_chart: ^0.66.0 # For traffic graph if needed
  
  # Utilities
  intl: ^0.19.0
  url_launcher: ^6.2.4
  path_provider: ^2.1.2
  shared_preferences: ^2.2.2
  
  # Assets
  flutter_svg: ^2.0.10

dev_dependencies:
  flutter_test:
    sdk: flutter
  flutter_lints: ^3.0.0

flutter:
  uses-material-design: true
  
  # assets:
  #   - assets/images/
